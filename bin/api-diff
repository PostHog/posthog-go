#!/usr/bin/env bash
#/ Usage: bin/api-diff [-u|--update]
#/ Description: Checks the public Go API snapshot.
source bin/helpers/_utils.sh
set_source_and_root_dir
set -euo pipefail

snapshot_file="api/public-api.txt"
update=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        -u|--update)
            update=true
            shift
            ;;
        -\?|-h|--help)
            grep '^#/' <"$0" | cut -c4-
            exit
            ;;
        *)
            echo "Unknown option: $1" >&2
            exit 1
            ;;
    esac
done

tmp_file="$(mktemp)"
cleanup() {
    rm -f "$tmp_file"
}
trap cleanup EXIT

{
    echo '# This file is generated by `bin/api-diff --update`.'
    echo '# Do not edit manually.'
    echo '# Public API scope: importable non-main packages in this module, excluding examples, cmd, and SDK compliance adapter packages.'
    echo '# Doc comments are intentionally excluded so documentation-only edits do not change this snapshot.'
    echo

    go list -f '{{.ImportPath}} {{.Name}}' ./... |
        awk '$2 != "main" { print $1 }' |
        grep -Ev '/(cmd|examples|sdk_compliance_adapter)(/|$)' |
        sort |
        while read -r package; do
            echo "## $package"
            echo
            go doc -all "$package" |
                awk '!/^[[:space:]]*\/\// && !/^    /'
            echo
        done
} > "$tmp_file"

if $update; then
    mkdir -p "$(dirname "$snapshot_file")"
    cp "$tmp_file" "$snapshot_file"
    echo "Updated $snapshot_file"
    exit
fi

if [[ ! -f "$snapshot_file" ]]; then
    echo "Missing public API snapshot: $snapshot_file" >&2
    echo "Run bin/api-diff --update to create it." >&2
    exit 1
fi

if diff -u "$snapshot_file" "$tmp_file"; then
    echo "Go public API snapshot is up to date."
else
    echo "Go public API changed. Run bin/api-diff --update if intentional." >&2
    exit 1
fi
